#!/usr/bin/with-contenv bash
# shellcheck shell=bash
set -e

### Set Defaults
POSTMASTER=${POSTMASTER:-"postmaster@example.org"}
HOSTNAME=${HOSTNAME:-"imap.example.org"}
LOG_LEVEL=${LOG_LEVEL:-"DEBUG"}
LOG_PATH=${LOG_PATH:-"/dev/stdout"}
LOG_DEBUG_PATH=${LOG_DEBUG_PATH:-"/dev/stdout"}
LOG_INFO_PATH=${LOG_INFO_PATH:-"/dev/stdout"}
GREETING_TEXT=${GREETING_TEXT:-"Ready"}
SSL_CRT_FILENAME=${SSL_CRT_FILENAME:-"/etc/dovecot/certs/tls.crt"}
SSL_KEY_FILENAME=${SSL_KEY_FILENAME:-"/etc/dovecot/certs/tls.key"}
DH_FILENAME=${DH_FILENAME:-"/etc/postfix/dh4096.pem"}
SKIP_FTS=${SKIP_FTS:-"n"}
FTS_HEAP=${FTS_HEAP:-512}
FTS_PROCS=${FTS_PROCS:-3}
DOVEADM_PASSWORD=${DOVEADM_PASSWORD:-""}

PASS_SCHEME=${PASS_SCHEME:-"SHA512-CRYPT"}
DEBUG=${DEBUG:-0}

### Config Helper - Fixed sed pattern to properly match config keys
function setConf {
	KEY="$1"
	VALUE="$2"
	FILE="$3"
	if [ -z "$KEY" ] || [ -z "$FILE" ]; then
		echo "Error: setConf requires KEY, VALUE, and FILE arguments"
		return 1
	fi
	echo "Setting conf: $KEY=$VALUE in ($FILE)"
  # Use | as delimiter to avoid issues with / in values (e.g. /dev/stdout).
  # Escape | and & in both KEY and VALUE to protect sed metacharacters.
  KEY_ESCAPED=$(printf '%s\n' "$KEY" | sed -e 's/[|&]/\\&/g')
  VALUE_ESCAPED=$(printf '%s\n' "$VALUE" | sed -e 's/[|&]/\\&/g')
  sed -i -e "s|^\s*${KEY_ESCAPED}\s*=.*|${KEY_ESCAPED}=${VALUE_ESCAPED}|g" "$FILE"
}

### Set Dovecot Config
DOVECOT_VER=$(dovecot --version | grep -oE '^[0-9]+\.[0-9]+\.[0-9]+')
setConf "dovecot_config_version" "$DOVECOT_VER" /etc/dovecot/dovecot.conf
setConf "dovecot_storage_version" "$DOVECOT_VER" /etc/dovecot/dovecot.conf

setConf "hostname" "$HOSTNAME" /etc/dovecot/conf.d/15-lda.conf
setConf "postmaster_address" "$POSTMASTER" /etc/dovecot/conf.d/15-lda.conf
setConf "recipient_delimiter" "+" /etc/dovecot/conf.d/15-lda.conf
setConf "lda_mailbox_autocreate " "yes" /etc/dovecot/conf.d/15-lda.conf
setConf "lda_mailbox_autosubscribe " "yes" /etc/dovecot/conf.d/15-lda.conf
setConf "mail_plugins" "sieve" /etc/dovecot/conf.d/15-lda.conf

setConf "mail_plugins" "imap_sieve" /etc/dovecot/conf.d/20-imap.conf 

setConf "auth_mechanisms" "plain login cram-md5" /etc/dovecot/conf.d/10-auth.conf 
setConf "mail_uid" "vmail" /etc/dovecot/conf.d/10-mail.conf
setConf "mail_gid" "mail" /etc/dovecot/conf.d/10-mail.conf

setConf "default_vsz_limit" "256M" /etc/dovecot/conf.d/10-master.conf
#### Set Greeting
setConf "login_greeting" "$GREETING_TEXT" /etc/dovecot/dovecot.conf

#### Set Loglevel Dovecot Loglevel
setConf "log_path" "$LOG_PATH" /etc/dovecot/conf.d/10-logging.conf
setConf "debug_log_path" "$LOG_DEBUG_PATH" /etc/dovecot/conf.d/10-logging.conf
setConf "info_log_path" "$LOG_INFO_PATH" /etc/dovecot/conf.d/10-logging.conf

if [ "${DEBUG}" -gt 0 ]; then
  ### DEBUGGING
  setConf "auth_debug_passwords" "yes" /etc/dovecot/conf.d/10-logging.conf
  setConf "mail_debug" "yes" /etc/dovecot/conf.d/10-logging.conf
  setConf "auth_debug" "yes" /etc/dovecot/conf.d/10-logging.conf
  setConf "auth_verbose" "yes" /etc/dovecot/conf.d/10-logging.conf
else
  setConf "auth_debug_passwords" "no" /etc/dovecot/conf.d/10-logging.conf
  setConf "mail_debug" "no" /etc/dovecot/conf.d/10-logging.conf
  setConf "auth_debug" "no" /etc/dovecot/conf.d/10-logging.conf
  setConf "auth_verbose" "no" /etc/dovecot/conf.d/10-logging.conf
fi


echo "Setting up /etc/dovecot/conf.d/auth-sql.conf.ext"
cat <<EOF >/etc/dovecot/conf.d/auth-sql.conf.ext
sql_driver = mysql

mysql maildb {
  host = ${DB_HOST}
  port = ${DB_PORT}
  dbname = ${DB_NAME}
  user = ${DB_USER}
  password = ${DB_PASS}
}

passdb sql {
  passdb_default_password_scheme = ${PASS_SCHEME}
  passdb_sql_query = SELECT username AS user, password, homedir AS userdb_home, ${VMAIL_UID} AS userdb_uid, ${VMAIL_GID} AS userdb_gid FROM mailbox WHERE username = '%{user}'
}

userdb sql {
  fields {
    uid = vmail
    gid = mail
    mail_home = /data/mail/%{user|domain}/%{user|username}
    mail_path = ~/mail
  }
  userdb_sql_query = SELECT homedir AS home, ${VMAIL_UID} AS uid, ${VMAIL_GID} AS gid, CONCAT(quota, 'B') AS quota_storage_size FROM mailbox WHERE username = '%{user}'
  userdb_sql_iterate_query = SELECT username AS user FROM mailbox
}
EOF
# Secure SQL auth config with database credentials
chmod 600 /etc/dovecot/conf.d/auth-sql.conf.ext

echo "Setting new certificate location"
# Validate SSL certificate files exist before configuring
if [ ! -f "$SSL_CRT_FILENAME" ]; then
  echo "ERROR: SSL certificate not found at $SSL_CRT_FILENAME"
  echo "Please mount or create certificate at this location"
  exit 1
fi
if [ ! -f "$SSL_KEY_FILENAME" ]; then
  echo "ERROR: SSL key not found at $SSL_KEY_FILENAME"
  echo "Please mount or create key at this location"
  exit 1
fi
if [ ! -f "$DH_FILENAME" ]; then
  echo "WARNING: DH parameters file not found at $DH_FILENAME"
  echo "This is optional but recommended for perfect forward secrecy"
fi

cat <<EOF > /etc/dovecot/conf.d/10-ssl.conf
ssl = required
ssl_server_cert_file = ${SSL_CRT_FILENAME}
ssl_server_key_file = ${SSL_KEY_FILENAME}
EOF

if [ -f "$DH_FILENAME" ]; then
  echo "ssl_server_dh_file = ${DH_FILENAME}" >> /etc/dovecot/conf.d/10-ssl.conf
fi
chmod 600 /etc/dovecot/conf.d/10-ssl.conf

echo "Configuring doveadm admin interface"
if [ -n "$DOVEADM_PASSWORD" ]; then
  echo "Using DOVEADM_PASSWORD from environment variable"
  cat <<EOF > /etc/dovecot/conf.d/91-doveadm.conf
# Create a listener for doveadm-server
service doveadm {
  user = vmail
  group = mail
  inet_listener doveadm {
    port = 3333
  }
}
doveadm_password = ${DOVEADM_PASSWORD}
EOF
  chmod 600 /etc/dovecot/conf.d/91-doveadm.conf
else
  echo "Warning: DOVEADM_PASSWORD not set - doveadm admin interface will be disabled"
  echo "To enable, set DOVEADM_PASSWORD environment variable"
  cat <<EOF > /etc/dovecot/conf.d/91-doveadm.conf
# doveadm admin interface disabled - DOVEADM_PASSWORD not configured
service doveadm {
  user = vmail
  group = mail
  inet_listener doveadm {
    port = 3333
  }
}
EOF
fi

if [[ "${SKIP_FTS}" =~ ^([yY][eE][sS]|[yY])+$ ]]; then
echo -e "\e[33mDetecting SKIP_FTS=y... not enabling Flatcurve (FTS) then...\e[0m"
echo -n 'quota acl zlib mail_crypt mail_crypt_acl mail_log notify listescape replication lazy_expunge' > /etc/dovecot/mail_plugins
echo -n 'quota imap_quota imap_acl acl zlib imap_zlib imap_sieve mail_crypt mail_crypt_acl notify listescape replication mail_log' > /etc/dovecot/mail_plugins_imap
echo -n 'quota sieve acl zlib mail_crypt mail_crypt_acl notify listescape replication' > /etc/dovecot/mail_plugins_lmtp
else
echo -e "\e[32mDetecting SKIP_FTS=n... enabling Flatcurve (FTS)\e[0m"
echo -n 'quota acl zlib mail_crypt mail_crypt_acl mail_log notify fts fts_flatcurve listescape replication lazy_expunge' > /etc/dovecot/mail_plugins
echo -n 'quota imap_quota imap_acl acl zlib imap_zlib imap_sieve mail_crypt mail_crypt_acl notify mail_log fts fts_flatcurve listescape replication' > /etc/dovecot/mail_plugins_imap
echo -n 'quota sieve acl zlib mail_crypt mail_crypt_acl fts fts_flatcurve notify listescape replication' > /etc/dovecot/mail_plugins_lmtp
fi

# Setting variables for indexer-worker inside fts.conf automatically according to mailcow.conf settings
if [[ "${SKIP_FTS}" =~ ^([nN][oO]|[nN])+$ ]]; then
  echo -e "\e[94mConfiguring FTS Settings...\e[0m"
  echo -e "\e[94mSetting FTS Memory Limit (per process) to ${FTS_HEAP} MB\e[0m"
  sed -i "s/vsz_limit\s*=\s*[0-9]*\s*MB*/vsz_limit=${FTS_HEAP} MB/" /etc/dovecot/conf.d/fts.conf
  echo -e "\e[94mSetting FTS Process Limit to ${FTS_PROCS}\e[0m"
  sed -i "s/process_limit\s*=\s*[0-9]*/process_limit=${FTS_PROCS}/" /etc/dovecot/conf.d/fts.conf
fi

# Validate dovecot configuration
echo "Validating Dovecot configuration..."
if doveconf -c /etc/dovecot/dovecot.conf >/dev/null 2>&1; then
  echo -e "\e[32m✓ Dovecot configuration is valid\e[0m"
else
  echo -e "\e[31m✗ Dovecot configuration validation failed\e[0m"
  doveconf -c /etc/dovecot/dovecot.conf || true
  exit 1
fi

echo -e "\e[32m[OK] Dovecot initialization complete\e[0m"